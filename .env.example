# WordPress REST API webhook URL (default: https://jobayergroup.com/wp-json/ai-router/v1/webhook)
WP_API_URL=https://yourdomain.com/wp-json/ai-router/v1/webhook

# WhatsApp phone number (with country code, no +)
WHATSAPP_PHONE=880130585531

# Auth directory for WhatsApp session storage (default: auth_info)
# Use /data/auth_info when using Railway persistent volume
AUTH_DIR=auth_info

# Port for the web UI (default: 8080)
PORT=8080
