# Your Cloudflare app URL (e.g., https://jobayer-group-career.workers.dev)
APP_URL=https://jobayer-group-career.workers.dev

# Optional: override webhook URL (defaults to APP_URL/api/whatsapp/webhook)
# WP_API_URL=

# Primary WhatsApp phone number (with country code, no +)
WHATSAPP_PHONE=880130585531

# Number of WhatsApp accounts (default: 1)
WHATSAPP_ACCOUNTS=1

# Auth directory for WhatsApp session storage (default: auth_info)
# Use /data/auth_info when using Railway persistent volume
AUTH_DIR=auth_info

# Port for the web UI (default: 8080)
PORT=8080
